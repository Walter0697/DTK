{
  "name": "dummyjson_users",
  "source": "dummyjson",
  "request": "curl -sS https://dummyjson.com/users",
  "content_path": "users",
  "notes": "Keep the user identity and profile fields that are commonly needed, while stripping secrets, device data, and financial/crypto subtrees.",
  "allow": [
    "[].id",
    "[].firstName",
    "[].lastName",
    "[].username",
    "[].email",
    "[].gender",
    "[].age",
    "[].role",
    "[].image",
    "[].company.name",
    "[].company.title",
    "[].address.city",
    "[].address.state",
    "[].university"
  ]
}
